# Distributed Deployment - App Server Configuration
# Copy to .env and customize

# =============================================================================
# REQUIRED - Must set before starting
# =============================================================================

# Session encryption secret (same across all app servers!)
SESSION_SECRET=

# PostgreSQL on infrastructure server
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:PASSWORD@infra-server:5432/cascadia

# RabbitMQ on infrastructure server
# Format: amqp://user:password@host:port/vhost
RABBITMQ_URL=amqp://cascadia:PASSWORD@infra-server:5672/cascadia

# MinIO/S3 on infrastructure server
S3_ENDPOINT=http://infra-server:9000
S3_ACCESS_KEY=cascadia
S3_SECRET_KEY=

# =============================================================================
# APPLICATION
# =============================================================================

# Port to expose (may vary per server if using host networking)
APP_PORT=3000

# Public URL (set to load balancer URL)
BASE_URL=https://plm.example.com

# Environment
NODE_ENV=production

# Image version (if using pre-built images)
APP_VERSION=latest

# =============================================================================
# STORAGE
# =============================================================================

S3_BUCKET=cascadia-vault
