# Single Server Deployment Configuration
# Copy to .env and customize

# =============================================================================
# REQUIRED - Must set before starting
# =============================================================================

# Session encryption secret (generate: openssl rand -hex 32)
SESSION_SECRET=

# Database password (use a strong password in production)
POSTGRES_PASSWORD=

# =============================================================================
# APPLICATION
# =============================================================================

# Port for web application
APP_PORT=3000

# Public URL (used for emails, OAuth callbacks)
BASE_URL=http://localhost:3000

# Environment mode
NODE_ENV=production

# =============================================================================
# DATABASE
# =============================================================================

POSTGRES_DB=cascadia
POSTGRES_USER=postgres
POSTGRES_PORT=5432

# =============================================================================
# OPTIONAL: pgAdmin
# =============================================================================

# Start with: docker-compose --profile tools up -d
PGADMIN_EMAIL=admin@cascadia.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
