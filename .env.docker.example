# Docker Environment Configuration
# Copy this file to .env when using Docker Compose

# Application
NODE_ENV=production
APP_PORT=3000
BASE_URL=http://localhost:3000

# PostgreSQL Database
POSTGRES_DB=cascadia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Database URL (automatically constructed for Docker)
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/cascadia

# Authentication
SESSION_SECRET=change-this-to-a-random-32-char-string-for-production

# File Storage
FILE_STORAGE_PATH=/app/storage/files
VAULT_ROOT=/app/vault
VAULT_TYPE=local

# Optional: pgAdmin (only if using 'tools' profile)
PGADMIN_PORT=5050
PGADMIN_EMAIL=admin@cascadia.local
PGADMIN_PASSWORD=admin

# OAuth Providers (Optional)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_REDIRECT_URI=http://localhost:3000/auth/callback/azure

# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# Email Configuration (Optional)
# SMTP_HOST=mail.example.com
# SMTP_PORT=587
# SMTP_USER=plm@example.com
# SMTP_PASS=password

# Messaging (Optional)
# MQTT_BROKER=tcp://mqtt.factory.local:1883
# MQTT_USERNAME=plm-system
# MQTT_PASSWORD=secure-password
