# Cloud Database Deployment Configuration
# Copy to .env and customize

# =============================================================================
# REQUIRED - Must set before starting
# =============================================================================

# Cloud database connection string
# AWS RDS:
#   DATABASE_URL=postgresql://cascadia:PASSWORD@mydb.abc123.us-east-1.rds.amazonaws.com:5432/cascadia?sslmode=require
# Google Cloud SQL (via proxy):
#   DATABASE_URL=postgresql://cascadia:PASSWORD@127.0.0.1:5432/cascadia
# Azure Database:
#   DATABASE_URL=postgresql://cascadia@server:PASSWORD@server.postgres.database.azure.com:5432/cascadia?sslmode=require
DATABASE_URL=

# Session encryption secret (generate: openssl rand -hex 32)
SESSION_SECRET=

# =============================================================================
# APPLICATION
# =============================================================================

APP_PORT=3000
BASE_URL=https://plm.example.com
NODE_ENV=production
APP_VERSION=latest

# =============================================================================
# FILE STORAGE
# =============================================================================

# Option 1: Local storage (default)
VAULT_TYPE=local

# Option 2: AWS S3
# VAULT_TYPE=s3
# S3_BUCKET=cascadia-vault
# S3_REGION=us-east-1
# S3_ACCESS_KEY=AKIAIOSFODNN7EXAMPLE
# S3_SECRET_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# Option 3: Google Cloud Storage (via S3 interop)
# VAULT_TYPE=s3
# S3_BUCKET=cascadia-vault
# S3_ENDPOINT=https://storage.googleapis.com
# S3_ACCESS_KEY=GOOGXXXXXXXX
# S3_SECRET_KEY=your-hmac-secret
