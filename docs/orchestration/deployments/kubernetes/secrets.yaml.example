# Cascadia Secrets
# Copy to secrets.yaml and fill in your values
# Values must be base64 encoded: echo -n 'value' | base64
#
# IMPORTANT: Do not commit secrets.yaml to version control!

apiVersion: v1
kind: Secret
metadata:
  name: cascadia-secrets
  namespace: cascadia
type: Opaque
stringData:
  # Database connection string
  # For RDS: postgresql://user:pass@mydb.rds.amazonaws.com:5432/cascadia?sslmode=require
  # For Cloud SQL: postgresql://user:pass@/cascadia?host=/cloudsql/project:region:instance
  database-url: "postgresql://cascadia:CHANGE_ME@postgresql:5432/cascadia"

  # Session encryption secret (generate: openssl rand -hex 32)
  session-secret: "CHANGE_ME_TO_RANDOM_32_CHAR_STRING"

  # S3/MinIO credentials (if using S3 storage)
  s3-access-key: ""
  s3-secret-key: ""

  # RabbitMQ credentials (if using job workers)
  rabbitmq-url: ""

  # Vault service token (if using separate vault service)
  vault-service-token: ""
