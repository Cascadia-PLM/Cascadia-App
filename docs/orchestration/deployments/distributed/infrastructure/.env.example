# Distributed Deployment - Infrastructure Configuration
# Copy to .env and customize

# =============================================================================
# REQUIRED - Must set before starting
# =============================================================================

# PostgreSQL
POSTGRES_PASSWORD=

# RabbitMQ
RABBITMQ_PASSWORD=

# MinIO (S3-compatible storage)
MINIO_PASSWORD=

# =============================================================================
# DATABASE
# =============================================================================

POSTGRES_DB=cascadia
POSTGRES_USER=postgres
POSTGRES_PORT=5432

# =============================================================================
# MESSAGE BROKER
# =============================================================================

RABBITMQ_USER=cascadia
RABBITMQ_VHOST=cascadia
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# =============================================================================
# OBJECT STORAGE
# =============================================================================

MINIO_USER=cascadia
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# OPTIONAL: pgAdmin
# =============================================================================

# Start with: docker-compose --profile tools up -d
PGADMIN_EMAIL=admin@cascadia.local
PGADMIN_PASSWORD=admin
PGADMIN_PORT=5050
