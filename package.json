{
  "name": "cascadia-plm",
  "version": "0.1.0",
  "description": "Code-first, type-safe Product Lifecycle Management (PLM) system with ECO-as-Branch versioning. Built with Hono + Vite + TanStack Router + PostgreSQL.",
  "license": "AGPL-3.0-or-later",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cascadia-PLM/Cascadia-App.git"
  },
  "homepage": "https://github.com/Cascadia-PLM/Cascadia-App#readme",
  "bugs": {
    "url": "https://github.com/Cascadia-PLM/Cascadia-App/issues"
  },
  "scripts": {
    "dev": "concurrently -n client,api -c blue,green \"npm run dev:client\" \"npm run dev:api\"",
    "dev:client": "vite --port 3000",
    "dev:api": "tsx src/server/dev.ts",
    "build": "vite build && npm run build:server && npm run build:jobs-worker",
    "build:server": "node scripts/build-server.mjs",
    "build:jobs-worker": "node scripts/build-jobs-worker.mjs",
    "serve": "node .output/server/index.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:setup": "tsx scripts/e2e-setup.ts",
    "test:e2e:full": "npm run db:reset:seed && npm run test:e2e",
    "lint": "eslint --max-warnings 185",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/seed-minimal.ts",
    "db:seed:catalog": "tsx scripts/seed-catalog.ts",
    "db:seed:demo": "tsx scripts/seed-demo-robot-arm.ts",
    "db:drop": "tsx scripts/drop-all-tables.ts",
    "db:reset": "tsx scripts/truncate-all.ts",
    "db:reset:seed": "tsx scripts/truncate-all.ts && tsx scripts/seed-minimal.ts",
    "db:drop:seed": "tsx scripts/drop-all-tables.ts && npx drizzle-kit push --force && tsx scripts/seed-minimal.ts",
    "demo:up": "docker compose -f docker-compose.demo.yml up -d",
    "demo:down": "docker compose -f docker-compose.demo.yml down",
    "demo:reset": "docker compose -f docker-compose.demo.yml down -v && docker compose -f docker-compose.demo.yml up -d",
    "demo:logs": "docker compose -f docker-compose.demo.yml logs -f app",
    "demo:build-data": "tsx scripts/build-demo-manifest.ts && tsx scripts/prepare-demo-cad.ts",
    "deploy:install": "tsx scripts/deploy/install.ts",
    "jobs:worker": "node .output/server/jobs-worker.mjs",
    "jobs:worker:dev": "tsx src/jobs-worker.ts",
    "cad:worker:dev": "docker compose --profile cad up cad-converter-dev --build -d && docker logs -f cascadia-cad-converter-dev",
    "cad:worker:stop": "docker compose --profile cad stop cad-converter-dev",
    "cad:worker:logs": "docker logs -f cascadia-cad-converter-dev",
    "cadgen:worker:dev": "docker compose --profile cad up cad-generator-dev --build -d && docker logs -f cascadia-cad-generator-dev",
    "cadgen:worker:stop": "docker compose --profile cad stop cad-generator-dev",
    "cadgen:worker:logs": "docker logs -f cascadia-cad-generator-dev",
    "workers:dev": "docker compose up -d rabbitmq && docker compose --profile cad up -d cad-converter-dev cad-generator-dev --build && tsx src/jobs-worker.ts",
    "workers:stop": "docker compose --profile cad stop cad-converter-dev cad-generator-dev",
    "workers:logs": "docker compose --profile cad logs -f cad-converter-dev cad-generator-dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.993.0",
    "@hono/node-server": "^1.19.14",
    "@node-rs/argon2": "^2.0.2",
    "@oslojs/crypto": "^1.0.1",
    "@oslojs/encoding": "^1.1.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.2",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/ai": "^0.2.2",
    "@tanstack/ai-anthropic": "^0.2.0",
    "@tanstack/ai-openai": "^0.2.1",
    "@tanstack/ai-react": "^0.2.2",
    "@tanstack/react-devtools": "^0.0.0",
    "@tanstack/react-form": "^1.27.1",
    "@tanstack/react-query": "^5.90.19",
    "@tanstack/react-router": "^1.139.14",
    "@tanstack/react-router-devtools": "^1.139.15",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.139.14",
    "@types/dagre": "^0.7.53",
    "@xyflow/react": "^12.9.3",
    "amqplib": "^0.10.9",
    "arctic": "^3.7.0",
    "dagre": "^0.8.5",
    "dotenv": "^17.2.3",
    "driver.js": "^1.4.0",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "hono": "^4.12.12",
    "lucide-react": "^0.544.0",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.7",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.0.6",
    "three": "^0.182.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.1.11",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@inquirer/prompts": "^8.0.2",
    "@playwright/test": "^1.49.0",
    "@tanstack/eslint-config": "^0.3.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/amqplib": "^0.10.8",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.0.5",
    "baseline-browser-mapping": "^2.9.2",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "jsdom": "^27.0.0",
    "ora": "^9.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0",
    "yaml": "^2.8.2"
  },
  "overrides": {
    "esbuild": ">=0.25.0"
  }
}
