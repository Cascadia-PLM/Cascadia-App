# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cascadia

# Authentication
SESSION_SECRET=change-this-to-a-random-32-char-string

# OAuth Providers (Optional)
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret
# AZURE_REDIRECT_URI=http://localhost:3000/auth/callback/azure

# GOOGLE_CLIENT_ID=your-client-id
# GOOGLE_CLIENT_SECRET=your-client-secret

# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Application
BASE_URL=http://localhost:3000
NODE_ENV=development

# File Storage
FILE_STORAGE_PATH=./storage/files

# Vault Configuration
VAULT_ROOT=./vault
VAULT_TYPE=local

# Email (Optional)
# SMTP_HOST=mail.example.com
# SMTP_PORT=587
# SMTP_USER=plm@example.com
# SMTP_PASS=password

# Messaging (Optional)
# MQTT_BROKER=tcp://mqtt.factory.local:1883
# MQTT_USERNAME=plm-system
# MQTT_PASSWORD=secure-password

# Jobs Server (RabbitMQ)
# Note: On Windows with Docker Desktop, the worker must run inside Docker
# Use: docker compose --profile dev up jobs-worker-dev -d
RABBITMQ_URL=amqp://cascadia:cascadia@localhost:5672

# Jobs Worker Settings (optional, for docker-compose)
# WORKER_CONCURRENCY=5
# JOB_TYPES=*
# JOB_TIMEOUT=300000

# When running PostgreSQL on Windows host with jobs worker in Docker:
# POSTGRES_HOST=host.docker.internal

# Encryption key for sensitive data at rest (API keys, etc.)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# Database SSL/TLS
# When NODE_ENV=production the app requires TLS unless you opt out. Set to
# "disable" for private-network deployments (e.g. compose-bundled postgres),
# or "require" to force TLS regardless of NODE_ENV.
# DATABASE_SSL=
#
# Alternatively, pass sslmode in the connection string (libpq style):
#   DATABASE_URL=postgresql://user:pass@host:5432/db?sslmode=disable
# Supported sslmode values: disable, require, verify-ca, verify-full.
# DATABASE_SSL takes precedence over ?sslmode= when both are set.
#
# Path to CA certificate for database SSL verification.
# Required when sslmode is verify-ca or verify-full; optional with require.
# DATABASE_CA_CERT_PATH=

# Email/SMTP (required for notification jobs in production)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=notifications@example.com
# SMTP_PASS=your-smtp-password
# SMTP_FROM=plm@example.com
