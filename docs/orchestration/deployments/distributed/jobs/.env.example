# Distributed Deployment - Jobs Server Configuration
# Copy to .env and customize

# =============================================================================
# REQUIRED - Must set before starting
# =============================================================================

# PostgreSQL on infrastructure server
DATABASE_URL=postgresql://postgres:PASSWORD@infra-server:5432/cascadia

# RabbitMQ on infrastructure server
RABBITMQ_URL=amqp://cascadia:PASSWORD@infra-server:5672/cascadia

# MinIO/S3 on infrastructure server
S3_ENDPOINT=http://infra-server:9000
S3_ACCESS_KEY=cascadia
S3_SECRET_KEY=

# =============================================================================
# WORKER CONFIGURATION
# =============================================================================

# Number of concurrent jobs per worker container
WORKER_CONCURRENCY=5

# Job types to process (* for all, or comma-separated list)
# Examples:
#   JOB_TYPES=*                              # All job types
#   JOB_TYPES=reports,notifications,cleanup  # General tasks
#   JOB_TYPES=conversion.cad                 # CAD conversions only
#   JOB_TYPES=conversion.office              # Office conversions only
JOB_TYPES=*

# Default job timeout in milliseconds
JOB_TIMEOUT=300000

# Number of worker container replicas
WORKER_REPLICAS=2

# =============================================================================
# STORAGE
# =============================================================================

S3_BUCKET=cascadia-vault

# =============================================================================
# IMAGE VERSION
# =============================================================================

JOBS_VERSION=latest
NODE_ENV=production
